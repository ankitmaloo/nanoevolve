## H64: Nesterov Blend Schedule 0.7→0.95 (WINNER: +0.063 BPB)
##
## Attack surface: Muon momentum schedule (training loop)
## Mechanism: Replace the production momentum warmup (0.85→0.95 over 300 steps)
##   with a slower Nesterov blend schedule (0.7→0.95 over 500 steps).
##   Lower initial momentum = more gradient responsiveness early in training.
## Result: Best Stage 4 mutation. 1.4765 BPB vs 1.5395 baseline.

--- a/nanochat/scripts/base_train.py  (production schedule)
+++ b/nanochat/scripts/base_train.py  (H64 mutation)
@@ production momentum schedule
-def get_muon_momentum(it):
-    frac = min(it / 300, 1)
-    return (1 - frac) * 0.85 + frac * 0.95
+# H64: Override momentum with Nesterov blend schedule
+# Applied per-step in training loop, not as a function override
+# blend = 0.7 + (0.95 - 0.7) * min(1.0, step / 500)
+# for group in optimizer.param_groups:
+#     if group['kind'] == 'muon':
+#         group['momentum'] = blend

--- a/training_loop (production)
+++ b/training_loop (H64 applied)
@@ after standard schedule application
+    if mutation == 'H64_nesterov_schedule':
+        blend = 0.7 + (0.95 - 0.7) * min(1.0, step / 500)
+        for group in optimizer.param_groups:
+            if group['kind'] == 'muon':
+                group['momentum'] = blend

## Key difference from production:
##   Production: 0.85 → 0.95 over 300 steps (momentum warmup)
##   H64:        0.70 → 0.95 over 500 steps (nesterov blend)
##   Lower start (0.70 vs 0.85) + slower warmup (500 vs 300 steps)
